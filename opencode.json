{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure/gpt-5.4",
  "small_model": "azure/gpt-5.4-mini",
  "provider": {
    "azure": {
      "options": {
        "apiKey": "{env:AZURE_OPENAI_KEY}",
        "baseURL": "https://glueo-se.openai.azure.com/openai",
        "resourceName": "glueo-se",
        "apiVersion": "preview"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 272000,
            "output": 32000
          },
          "reasoningEffort": "high"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "limit": {
            "context": 272000,
            "output": 32000
          }
        }
      }
    }
  },
  "mcp": {
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com"
    }
  },
  "instructions": [
    ".opencode/rules/formatting-guidelines.md",
    ".opencode/rules/json-config-only.md",
    ".opencode/rules/minimal-diff.md",
    ".opencode/rules/no-confirmation-prompts.md",
    ".opencode/rules/prompt-engineering-knowledge.md"
  ]
}
