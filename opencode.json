{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure/gpt-5.4",
  "small_model": "azure/gpt-5.4-mini",
  "provider": {
    "azure": {
      "options": {
        "apiKey": "{env:AZURE_OPENAI_KEY}",
        "baseURL": "{env:AZURE_BASE_URL}",
        "resourceName": "{env:AZURE_RESOURCE_NAME}",
        "apiVersion": "preview"
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 272000,
            "output": 32000
          },
          "reasoningEffort": "high"
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "limit": {
            "context": 272000,
            "output": 32000
          }
        },
        "gpt-5.4-pro": {
          "name": "GPT-5.4 pro",
          "limit": { "context": 1050000, "output": 128000 },
          "reasoningEffort": "high"
        }
      }
    }
  },
  "mcp": {
    "apify": {
      "type": "remote",
      "url": "https://mcp.apify.com"
    }
  },
  "instructions": [
    ".opencode/rules/apify-production.md",
    ".opencode/rules/formatting-guidelines.md",
    ".opencode/rules/json-config-only.md",
    ".opencode/rules/minimal-diff.md",
    ".opencode/rules/native-addon-boundary.md",
    ".opencode/rules/no-confirmation-prompts.md",
    ".opencode/rules/prompt-engineering-knowledge.md",
    ".opencode/rules/security.md",
    ".opencode/rules/spec-maintenance.md",
    ".opencode/rules/test-maintenance.md",
    ".opencode/rules/testing.md"
  ]
}
