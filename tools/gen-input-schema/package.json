{
  "name": "@contextractor/gen-input-schema",
  "version": "0.1.0",
  "private": true,
  "description": "Build-time generator that emits Apify INPUT_SCHEMA.json from the @contextractor/schema Zod source of truth.",
  "type": "module",
  "bin": {
    "gen-input-schema": "dist/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/schema": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
