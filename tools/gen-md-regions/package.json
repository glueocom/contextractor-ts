{
  "name": "@contextractor/gen-md-regions",
  "version": "0.1.0",
  "private": true,
  "description": "Build-time generator that rewrites schema-derived regions in Contextractor markdown files in place.",
  "type": "module",
  "bin": {
    "gen-md-regions": "dist/main.js"
  },
  "scripts": {
    "build": "pnpm run fix && tsc -p tsconfig.json",
    "fix": "biome check . --fix --unsafe && biome format --write . && biome check .",
    "start": "tsx src/main.ts",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/schema": "workspace:*",
    "@contextractor/standalone": "workspace:*",
    "commander": "^14.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
