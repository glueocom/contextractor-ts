    "waitUntil": "domcontentloaded",
    "save": [
        "markdown"
    ],
    "saveDestination": [
        "dataset"
    ],
    "maxRequestRetries": 3,
    "pageLoadTimeoutSecs": 60,
    "maxCrawlPages": 5,
    "linkSelector": "a[href]",
    "includeUrlGlobs": [
        {
            "glob": "https://crawlee.dev/docs/**"
        }
    ]
}
