{
  "name": "@contextractor/schema",
  "version": "0.1.0",
  "private": true,
  "description": "Single source of truth for Contextractor input — Zod 4 schema plus the Apify INPUT_SCHEMA generator that compiles it to disk.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
