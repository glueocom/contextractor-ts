{
  "name": "@contextractor/extraction",
  "version": "0.1.0",
  "private": true,
  "description": "Pure TypeScript content-extraction package backed by rs-trafilatura via napi-rs.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm run fix && tsc -p tsconfig.json",
    "fix": "biome check . --fix --unsafe && biome format --write . && biome check .",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/extraction-native": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
