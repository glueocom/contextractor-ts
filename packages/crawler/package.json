{
  "name": "@contextractor/crawler",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Playwright crawler for Contextractor. Wires Ghostery adblocker, infiniteScroll, and extraction into a reusable factory.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/extraction": "workspace:*",
    "@ghostery/adblocker-playwright": "^2.14.0",
    "crawlee": "^3.13.10",
    "playwright": "^1.50.1"
  },
  "optionalDependencies": {
    "@duckduckgo/autoconsent": "^14.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
