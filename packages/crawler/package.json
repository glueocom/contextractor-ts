{
  "name": "@contextractor/crawler",
  "version": "0.1.0",
  "private": true,
  "description": "Shared Crawlee + Playwright crawler package for Contextractor.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "pnpm run fix && tsc -p tsconfig.json",
    "fix": "biome check . --fix --unsafe && biome format --write . && biome check .",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/extraction": "workspace:*",
    "@ghostery/adblocker-playwright": "^2.17.3",
    "crawlee": "^3.16.0",
    "playwright": "^1.60.0"
  },
  "optionalDependencies": {
    "@duckduckgo/autoconsent": "^14.84.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
