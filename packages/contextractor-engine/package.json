{
    "name": "@contextractor/engine",
    "version": "0.3.12",
    "description": "TypeScript engine wrapping rs-trafilatura via napi-rs",
    "license": "Apache-2.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": ["dist", "native/index.js", "native/index.d.ts", "native/*.node"],
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@contextractor/engine-native": "workspace:*"
    },
    "devDependencies": {
        "@types/node": "^22.10.0",
        "typescript": "^5.7.0",
        "vitest": "^2.1.8"
    }
}
