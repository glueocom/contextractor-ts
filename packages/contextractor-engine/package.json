{
  "name": "@contextractor/engine",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript content-extraction engine. Built on rs-trafilatura (extraction) and Crawlee (TS crawler driving Playwright).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/engine-native": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.19.17",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
