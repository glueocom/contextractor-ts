{
  "name": "contextractor-workspace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm run fix && turbo build",
    "test": "turbo test",
    "lint": "biome check .",
    "fix": "biome check . --fix --unsafe && biome format --write . && biome check .",
    "format": "biome format --write .",
    "check": "biome check .",
    "docs:update": "pnpm -F @contextractor/gen-md-regions start",
    "docs:check": "pnpm docs:update && git diff --exit-code -- '**/*.md'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.7.0",
    "turbo": "^2.9.12",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "file-type@>=13.0.0 <21.3.1": ">=21.3.1",
      "file-type@>=20.0.0 <=21.3.1": ">=21.3.2"
    }
  }
}
