{
  "name": "contextractor-workspace",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/*/native",
    "packages/*/native/npm/*",
    "tools/*"
  ],
  "packageManager": "npm@10.0.0",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "test": "npm run test -ws --if-present",
    "lint": "npm run lint -ws --if-present",
    "format": "npm run format -ws --if-present",
    "check": "npm run check -ws --if-present",
    "docs:update": "npm run start -w @contextractor/gen-md-regions",
    "docs:check": "npm run docs:update && git diff --exit-code -- '**/*.md'",
    "opencode:sync": "npm run start -w @contextractor/opencode-sync"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0",
    "@napi-rs/cli": "^2.18.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}
