{
  "name": "@contextractor/standalone",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone CLI for Contextractor. Built on rs-trafilatura and Crawlee.",
  "type": "module",
  "bin": {
    "contextractor": "dist/cli.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/crawler": "workspace:*",
    "@contextractor/extraction": "workspace:*",
    "@contextractor/schema": "workspace:*",
    "commander": "^14.0.3",
    "crawlee": "^3.16.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
