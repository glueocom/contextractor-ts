{
  "name": "@contextractor/standalone",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone CLI for Contextractor. Built on rs-trafilatura and Crawlee.",
  "type": "module",
  "bin": {
    "contextractor": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/engine": "workspace:*",
    "@contextractor/schema": "workspace:*",
    "commander": "^12.1.0",
    "crawlee": "^3.13.10",
    "playwright": "^1.50.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.19.17",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
