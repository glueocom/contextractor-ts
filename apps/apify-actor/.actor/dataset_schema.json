{
  "actorSpecification": 1,
  "fields": {
    "loadedUrl": {
      "type": "string",
      "description": "The URL that was loaded"
    },
    "httpStatus": {
      "type": "integer",
      "description": "HTTP response status code"
    },
    "loadedAt": {
      "type": "string",
      "description": "ISO 8601 timestamp when the page was loaded"
    },
    "metadata": {
      "type": "object",
      "description": "Extracted page metadata"
    },
    "original": {
      "type": "object",
      "description": "Raw page HTML captured before extraction. Present when \"original\" is in save."
    },
    "txt": {
      "type": "object",
      "description": "Extracted plain text. Present when \"txt\" is in save."
    },
    "markdown": {
      "type": "object",
      "description": "Extracted Markdown. Present when \"markdown\" is in save."
    },
    "json": {
      "type": "object",
      "description": "Extracted structured JSON with metadata. Present when \"json\" is in save."
    },
    "html": {
      "type": "object",
      "description": "Cleaned extracted HTML. Present when \"html\" is in save."
    }
  },
  "views": {
    "overview": {
      "title": "Overview",
      "transformation": {
        "fields": [
          "loadedUrl",
          "httpStatus",
          "metadata.title",
          "metadata.lang"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "loadedUrl": {
            "label": "URL",
            "format": "link"
          },
          "httpStatus": {
            "label": "Status",
            "format": "number"
          },
          "metadata.title": {
            "label": "Title",
            "format": "text"
          },
          "metadata.lang": {
            "label": "Language",
            "format": "text"
          }
        }
      }
    }
  }
}
