{
  "name": "@contextractor/apify",
  "version": "0.1.0",
  "private": true,
  "description": "Apify Actor that crawls websites and extracts main-content text. Built on rs-trafilatura and Crawlee.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "pnpm -F @contextractor/gen-input-schema start && pnpm -w docs:update && tsc -p tsconfig.json",
    "deploy": "node scripts/deploy.mjs",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check ."
  },
  "dependencies": {
    "@contextractor/crawler": "workspace:*",
    "@contextractor/extraction": "workspace:*",
    "@contextractor/schema": "workspace:*",
    "apify": "^3.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
